#!/usr/bin/env python3
import os, sys, subprocess, re

def nat_key(s):
    return [int(t) if t.isdigit() else t.lower() for t in re.split(r'(\d+)', s)]

def main():
    if len(sys.argv) != 2 or os.path.isdir(sys.argv[1]):
        os.execvp("imv", ["imv"] + sys.argv[1:])
    target = os.path.abspath(sys.argv[1])
    dir_path = os.path.dirname(target)
    col, order, smart = "NAME", "ASCENDING", "false"
    try:
        res = subprocess.run(["gio", "info", "-a", "metadata::thunar-sort-column,metadata::thunar-sort-order", dir_path], capture_output=True, text=True)
        for l in res.stdout.splitlines():
            if "column" in l: col = l.split()[-1]
            if "order" in l: order = l.split()[-1]
        smart = subprocess.run(["xfconf-query", "-c", "thunar", "-p", "/smart-sort"], capture_output=True, text=True).stdout.strip()
    except: pass

    exts = {".png", ".jpg", ".jpeg", ".gif", ".svg", ".bmp", ".webp", ".heic", ".heif", ".avif", ".jxl", ".qoi", ".tiff", ".tif"}
    files = [f for f in os.listdir(dir_path) if os.path.splitext(f)[1].lower() in exts]
    if os.path.basename(target) not in files: files.append(os.path.basename(target))

    rev = "DESCENDING" in order
    key_map = {
        "SIZE": lambda f: os.path.getsize(os.path.join(dir_path, f)),
        "DATE_MODIFIED": lambda f: os.path.getmtime(os.path.join(dir_path, f)),
        "TYPE": lambda f: (os.path.splitext(f)[1].lower(), nat_key(f) if smart=="true" else f.lower())
    }
    key_fn = key_map.get(col.replace("THUNAR_COLUMN_", ""), lambda f: nat_key(f) if smart=="true" else f.lower())
    files.sort(key=key_fn, reverse=rev)
    os.execvp("imv", ["imv", "-n", target] + [os.path.join(dir_path, f) for f in files])

if __name__ == "__main__": main()
